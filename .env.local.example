# =============================================
# Supabase 設定
# Supabaseダッシュボード > Project Settings > API から取得
# =============================================

# プロジェクトURL（例: https://xxxxxxxxxxxx.supabase.co）
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# anon公開キー（フロントエンドから安全に使える）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# サービスロールキー（サーバーサイドのみ。絶対にフロントに露出させないこと）
# Supabaseダッシュボード > Project Settings > API > service_role から取得
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================
# アプリ設定
# =============================================

# サイトURL（ローカル開発時: http://localhost:3000）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
